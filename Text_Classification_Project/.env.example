# Environment Configuration Template
# Copy this to .env and fill in your values

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-change-this-in-production

# ============================================================================
# TENSORFLOW/KERAS CONFIGURATION
# ============================================================================
TF_CPP_MIN_LOG_LEVEL=2
TF_FORCE_GPU_ALLOW_GROWTH=true
TF_CPP_VMODULE=autotuner=1

# ============================================================================
# STREAMLIT CONFIGURATION
# ============================================================================
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_CLIENT_SHOWFIGURETOOLTIP=true

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false
API_WORKERS=4

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================
MODEL_PATH=saved_models/text_classification_model.h5
TOKENIZER_PATH=saved_models/tokenizer.pickle
CONFIG_PATH=saved_models/config.pickle

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================================================
# DATABASE CONFIGURATION (if needed)
# ============================================================================
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=user
# DB_PASSWORD=password
# DB_NAME=text_classification

# ============================================================================
# EXTERNAL SERVICES (if deploying to cloud)
# ============================================================================
# AWS
# AWS_ACCESS_KEY_ID=your-key-here
# AWS_SECRET_ACCESS_KEY=your-secret-here
# AWS_REGION=us-east-1

# Google Cloud
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
# GCP_PROJECT_ID=your-project-id

# Azure
# AZURE_STORAGE_ACCOUNT=your-account
# AZURE_STORAGE_KEY=your-key

# ============================================================================
# SECURITY
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# PERFORMANCE
# ============================================================================
CACHE_TTL=3600
MAX_WORKERS=4
REQUEST_TIMEOUT=30

# ============================================================================
# BATCH PROCESSING
# ============================================================================
MAX_BATCH_SIZE=1000
BATCH_TIMEOUT=60

# ============================================================================
# MONITORING & ALERTING (if applicable)
# ============================================================================
# SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
# DATADOG_API_KEY=your-datadog-api-key
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
